{
  "name": "@involvex/bunpad-native",
  "description": "BunPad Native is a native Windows application that provides a rich text editor with a focus on performance and extensibility.",
  "author": "involvex",
  "license": "MIT",
  "homepage": "https://github.com/involvex/bunpadnative",
  "repository": {
    "type": "git",
    "url": "https://github.com/involvex/bunpadnative.git"
  },
  "bugs": {
    "url": "https://github.com/involvex/bunpadnative/issues"
  },
  "keywords": [
    "editor",
    "text editor",
    "native",
    "windows",
    "typescript"
  ],
  "version": "0.1.0",
  "private": true,
  "bin": {
    "bunpad": "./dist/bunpad.exe"
  },
  "workspaces": [
    "extensions/*"
  ],
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify": "bun run typecheck && bun run lint:fix && bun run format && bun run test:menu && bun run test:document && bun run test:editor && bun run test:highlight && bun run test:charformat && bun run test:charformat-integration && bun run test:contrast && bun run test:cli && bun run test:smoke && bun run test:plugins && bun run test:extensions",
    "test:smoke": "bun run scripts/smoke-test.ts",
    "test:plugins": "bun run scripts/plugin-test.ts",
    "test:extensions": "bun run scripts/extension-test.ts",
    "test:menu": "bun run scripts/menu-test.ts",
    "test:document": "bun run scripts/document-test.ts",
    "test:editor": "bun run scripts/editor-test.ts",
    "test:highlight": "bun run scripts/highlight-test.ts",
    "test:cli": "bun run scripts/cli-test.ts",
    "test:charformat": "bun run scripts/charformat-test.ts",
    "test:charformat-integration": "bun run scripts/charformat-integration-test.ts",
    "test:contrast": "bun run scripts/contrast-test.ts",
    "build": "bun run scripts/build.ts",
    "prebuild": "bun run verify"
  },
  "dependencies": {
    "@bun-win32/comdlg32": "^1.0.0",
    "@bun-win32/core": "^1.1.2",
    "@bun-win32/kernel32": "^1.0.25",
    "@bun-win32/user32": "^3.0.21",
    "bun-types": "^1.3.14",
    "vscode": "file:./vscode-shim"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "imports": {
    "vscode": "./src/vscode/index.ts"
  }
}
